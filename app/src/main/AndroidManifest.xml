<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Add the permissions your specific app needs here. INTERNET is the most
         common; the rest of these are commented placeholders. -->
    <!-- <uses-permission android:name="android.permission.INTERNET" /> -->

    <!-- NFC permission is declared here mainly so the OS recognises this app
         as an NFC handler. We don't actively read tags ourselves; instead, the
         user writes a habit's `habittracker://habit/complete/<id>` URL onto a
         tag with any tag-writer app. When tapped, Android delivers a VIEW
         intent for that URL to NfcCompletionActivity below. -->
    <uses-permission android:name="android.permission.NFC" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.App"
        android:enableOnBackInvokedCallback="true"
        tools:targetApi="35">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.App.Main">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <!-- "Open the app to this habit" deep link, used when the NFC
                 action is set to OpenApp. The activity inspects the intent
                 data on startup and marks the habit complete. -->
            <intent-filter android:autoVerify="false">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data
                    android:scheme="habittracker"
                    android:host="habit"
                    android:pathPrefix="/open" />
            </intent-filter>
        </activity>

        <!-- Receives the NFC tag's deep link, decides what to do based on the
             user's NfcAction setting (background-complete / overlay / open
             the app), and finishes itself. Themed transparent so the
             "background" mode shows literally nothing on screen. -->
        <activity
            android:name=".nfc.NfcCompletionActivity"
            android:exported="true"
            android:noHistory="true"
            android:excludeFromRecents="true"
            android:taskAffinity=""
            android:launchMode="singleTask"
            android:theme="@style/Theme.App.Transparent">
            <intent-filter android:autoVerify="false">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data
                    android:scheme="habittracker"
                    android:host="habit"
                    android:pathPrefix="/complete" />
            </intent-filter>
        </activity>

    </application>

</manifest>
